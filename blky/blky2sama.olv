	procedure	do_blk_mcvm_cpu_asm
	{
		var		cmp;
		macro	iasm;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	iasm=$(do_$(dxml));
				}
			}
		}
		pgsub	"\\t","	",iasm;
		pgsub	"\\n",$,,iasm;
		pgsub	"#","##",iasm;
		pgsub	"&lt;","<",iasm;

		// assembler
		fprint	fout,$(iasm)$,;
	}
	procedure	do_blk_mcvm_cpu_cend
	{
		var		cmp;
		macro	opcd;
		macro	nval;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	opcd=$(do_$(dxml));
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					mlet	nval=$(do_$(dxml));
				}
			}
		}
		tolower		opcd;
		strcmp	cmp=$(opcd),"cendw";
		if (cmp)
		{
			// ERROR:
			errmsg	"mcvm_cpu_cend: illegal operation ("$(opcd)")";
			leave	stop_error;
		}
		mlet	opcd="cend";
		mlet	do_blk_mcvm_cpu_cend=$(opcd)" ("$(nval)")";

		// assembler
		fprint	fout,"// convert endian: "$(opcd)" ("$(nval)")"$,;
		fprint	fout,$(opcd)$,;
	}
	procedure	do_blk_mcvm_cpu_exsg
	{
		var		cmp;
		macro	opcd;
		macro	nval;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	opcd=$(do_$(dxml));
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					mlet	nval=$(do_$(dxml));
				}
			}
		}
		tolower		opcd;
		strcmp	cmp=$(opcd),"exsgw";
		if (cmp)
		{
			// ERROR:
			errmsg	"mcvm_cpu_exsg: illegal operation ("$(opcd)")";
			leave	stop_error;
		}
		mlet	opcd="exsg";
		mlet	do_blk_mcvm_cpu_exsg=$(opcd)" ("$(nval)")";

		// assembler
		fprint	fout,"// sign extend: "$(opcd)" ("$(nval)")"$,;
		fprint	fout,"dupl"$,;					// X,X
		fprint	fout,"and	BYTE_SG"$,;			// X,X&BSG
		asm_label;
		fprint	fout,"njmp	"$(asm_label)$,;	// X
		fprint	fout,"or	0xff00"$,;			// X|0xff00
		fprint	fout,$(asm_label)":"$,;			// exsg(X)
	}
	procedure	do_blk_mcvm_cpu_irqen
	{
		var		cmp;
		macro	enlv;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	enlv=$(do_$(dxml));
				}
			}
		}

		// assembler
		strcmp	cmp=$(enlv),"_0",right;
		if (cmp=0)
		{
			fprint	fout,"// interrupts disable"$,;
			fprint	fout,"ijal	_rtlb_null"$,;
		}
		else
		{
			fprint	fout,"// interrupts enable"$,;
			fprint	fout,"ijal	[_rtlb_int_vec]"$,;
		}
	}
