	procedure	do_blk_mcoc_matf_itof
	{
		var		cmp;
		macro	nval;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					mlet	nval=$(do_$(dxml));
				}
			}
		}
		mlet	do_blk_mcoc_matf_itof="float ("$(nval)")";
		opt_fpu_need=true;

		// assembler
		fprint	fout,"// float (int ("$(nval)"))"$,;
if (true)
{
//	%%%%%%%%%%%%%%%%	blky2sama_math.incl
		fprint	fout,"dupl"$,;								// A,A
		fprint	fout,"swap	false	// 0 or positive"$,;	// A,false,A
		fprint	fout,"and	SGN_BIT"$,;						// A,false,A&SGN
		asm_label;
		fprint	fout,"njmp	"$(asm_label)"_else"$,;			// A,false
		fprint	fout,"or	true	// negative"$,;			// A,true
		fprint	fout,"swap"$,;								// true,A
		fprint	fout,"neg"$,;								// true,-A
		fprint	fout,"jmp	"$(asm_label)"_endif"$,;
		fprint	fout,$(asm_label)"_else:"$,;
		fprint	fout,"swap"$,;								// false,A
		fprint	fout,$(asm_label)"_endif:"$,;
		fprint	fout,"fhalf	0"$,;							// Cond,half(A')
		fprint	fout,"swap"$,;								// half(A'),Cond
		fprint	fout,"njmp	"$(asm_label)"_posi"$,;			// half(A')
		fprint	fout,"fneg	0"$,;							// -half(A')
		fprint	fout,$(asm_label)"_posi:"$,;
}
else
{
		fprint	fout,"itof*"$,;
}
	}
	procedure	do_blk_mcoc_matf_ftoi
	{
		var		cmp;
		macro	nval;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					mlet	nval=$(do_$(dxml));
				}
			}
		}
		mlet	do_blk_mcoc_matf_ftoi="int ("$(nval)")";
		opt_fpu_need=true;

		// assembler
		fprint	fout,"// int (float ("$(nval)"))"$,;
if (true)
{
//	%%%%%%%%%%%%%%%%	blky2sama_math.incl
		fprint	fout,"dupl"$,;								// A,A
		fprint	fout,"swap	false	// 0 or positive"$,;	// A,false,A
		fprint	fout,"and	SGN_BIT"$,;						// A,false,A&SGN
		asm_label;
		fprint	fout,"njmp	"$(asm_label)"_else"$,;			// A,false
		fprint	fout,"or	true	// negative"$,;			// A,true
		fprint	fout,"swap"$,;								// true,A
		fprint	fout,"fneg	0"$,;							// true,-A
		fprint	fout,"jmp	"$(asm_label)"_endif"$,;
		fprint	fout,$(asm_label)"_else:"$,;
		fprint	fout,"swap"$,;								// false,A
		fprint	fout,$(asm_label)"_endif:"$,;
		fprint	fout,"fuint	0"$,;							// Cond,int(A')
		fprint	fout,"swap"$,;								// int(A'),Cond
		fprint	fout,"njmp	"$(asm_label)"_posi"$,;			// int(A')
		fprint	fout,"neg"$,;								// -int(A')
		fprint	fout,$(asm_label)"_posi:"$,;
}
else
{
		fprint	fout,"ftoi*"$,;
}
	}
	procedure	do_blk_logic_boolean
	{
		var		cmp;
		macro	bval;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	bval=$(do_$(dxml));
					tolower		bval;
				}
			}
		}
		mlet	do_blk_logic_boolean=$(bval);

