	}
	procedure	do_blk_mcvm_mem_array_ref
	{
		var		cmp;
		macro	vnam;
		macro	nidx;

		// assembler
		fprint	fout,"// array get"$,;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	vnam=$(do_$(dxml));
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					mlet	nidx=$(do_$(dxml));
				}
			}
		}
		mlet	do_blk_mcvm_mem_array_ref=$(vnam)"["$(nidx)"]";

		// assembler
		fprint	fout,"// "$(vnam)"["$(nidx)"]"$,;
		fprint	fout,"asl"$,;
		fprint	fout,"add	["$(vnam)"]"$,;
		fprint	fout,"ldw"$,;
	}
	procedure	do_blk_mcvm_mem_array_set
	{
		var		cmp;
		macro	vnam;
		macro	nidx;
		macro	nval;

		// assembler
		fprint	fout,"// array set"$,;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	vnam=$(do_$(dxml));
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"IDX";
					if (cmp=0)
					{
						mlet	nidx=$(do_$(dxml));
					}
					strcmp	cmp=$(dnam),"VAL";
					if (cmp=0)
					{
						mlet	nval=$(do_$(dxml));
					}
				}
			}
		}

		// assembler
		fprint	fout,"// "$(vnam)"["$(nidx)"]="$(nval)$,;
		fprint	fout,"swap"$,;
		fprint	fout,"asl"$,;
		fprint	fout,"add	["$(vnam)"]"$,;
		fprint	fout,"stw"$,;
	}
	procedure	do_blk_mcvm_mem_read
	{
		var		cmp;
		macro	siz;
		macro	asiz;
		macro	adr;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	siz=$(do_$(dxml));
					strcmp	cmp=$(siz),"B",ics_left;
					if (cmp=0)
					{
						mlet	asiz="byte";
					}
					strcmp	cmp=$(siz),"W",ics_left;
					if (cmp=0)
					{
						mlet	asiz="word";
					}
					strcmp	cmp=$(siz),"L",ics_left;
					if (cmp=0)
					{
						mlet	asiz="long";
					}
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					mlet	adr=$(do_$(dxml));
				}
			}
		}
		tolower		siz;
		mlet	do_blk_mcvm_mem_read=$(asiz)"["$(adr)"]";

		// check
		strcmp	cmp=$(siz),"l";
		if (cmp=0)
		{
			// ERROR:
			errmsg	"mcvm_mem_read: long word access not supported";
			leave	stop_error;
		}

		// assembler
		fprint	fout,"// memory read "$(asiz)"["$(adr)"]"$,;
		fprint	fout,"ld"$(siz)$,;
	}
	procedure	do_blk_mcvm_mem_write
	{
		var		cmp;
		macro	siz;
		macro	asiz;
		macro	adr;
		macro	dat;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	siz=$(do_$(dxml));
					strcmp	cmp=$(siz),"B",ics_left;
					if (cmp=0)
					{
						mlet	asiz="byte";
					}
					strcmp	cmp=$(siz),"W",ics_left;
					if (cmp=0)
					{
						mlet	asiz="word";
					}
					strcmp	cmp=$(siz),"L",ics_left;
					if (cmp=0)
					{
						mlet	asiz="long";
					}
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"ADR";
					if (cmp=0)
					{
						mlet	adr=$(do_$(dxml));
					}
					strcmp	cmp=$(dnam),"DAT";
					if (cmp=0)
					{
						mlet	dat=$(do_$(dxml));
					}
				}
			}
		}
		tolower		siz;

		// check
		strcmp	cmp=$(siz),"l";
		if (cmp=0)
		{
			// ERROR:
			errmsg	"mcvm_mem_write: long word access not supported";
			leave	stop_error;
		}

		// assembler
		fprint	fout,"// memory write "$(asiz)"["$(adr)"]="$(dat)$,;
		fprint	fout,"swap"$,;
		fprint	fout,"st"$(siz)$,;
	}
