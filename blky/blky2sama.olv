	procedure	do_blk_logic_ternary
	{
		var		cmp;
		var		iblk;
		macro	iexp;
		macro	vthn;
		macro	vels;

		// assembler
		asm_label;
		macro	alab=$(asm_label);
		fprint	fout,$,;
		fprint	fout,"// if test"$,;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"IF";
					if (cmp=0)
					{
						iblk=@(iblk | 0x01);
						mlet	iexp=$(do_$(dxml));

						// assembler
						fprint	fout,"// test ("$(iexp)")"$,;
						fprint	fout,"njmp	"$(alab)"_else"$,;
						fprint	fout,$,;
						fprint	fout,"// then"$,;
					}
					strcmp	cmp=$(dnam),"THEN";
					if (cmp=0)
					{
						iblk=@(iblk | 0x02);
						mlet	vthn=$(do_$(dxml));

						// assembler
						fprint	fout,"// then ("$(vthn)")"$,;
						fprint	fout,"jmp	"$(alab)"_endif"$,;
						fprint	fout,$,;
						fprint	fout,"// else"$,;
						fprint	fout,$(alab)"_else:"$,;
					}
					strcmp	cmp=$(dnam),"ELSE";
					if (cmp=0)
					{
						iblk=@(iblk | 0x04);
						mlet	vels=$(do_$(dxml));

						// assembler
						fprint	fout,$,;
						fprint	fout,"// else ("$(vels)")"$,;
						fprint	fout,$(alab)"_endif:"$,;
					}
				}
			}
		}
		if (iblk!=0x07)
		{
			// ERROR:
			errmsg "logic_ternary: inhibited empty block.";
			leave	stop_error;
		}
		index	cmp=$(vthn)," ";
		if (cmp>0)
		{
			mlet	vthn="("$(vthn)")";
		}
		index	cmp=$(vels)," ";
		if (cmp>0)
		{
			mlet	vels="("$(vels)")";
		}
		mlet	do_blk_logic_ternary="("$(iexp)")? "$(vthn)": "$(vels);

		// assembler
		fprint	fout,$,;
		fprint	fout,"// end of test ("$(iexp)")? "$(vthn)": "$(vels)$,;
	}
	procedure	do_blk_logic_compare
	{
		var		cmp;
		macro	opr;
		macro	lval;
		macro	rval;
		macro	mne;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	opr=$(do_$(dxml));
					tolower		opr;
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"A";
					if (cmp=0)
					{
						mlet	lval=$(do_$(dxml));
					}
					else
					{
						mlet	rval=$(do_$(dxml));
					}
				}
			}
		}
		index	cmp=$(lval)," ";
		if (cmp>0)
		{
			mlet	lval="("$(lval)")";
		}
		index	cmp=$(rval)," ";
		if (cmp>0)
		{
			mlet	rval="("$(rval)")";
		}

		// operator
		mlet	mne="xxx";
		strcmp	cmp=$(opr),"eq";
		if (cmp=0)
		{
			mlet	opr="==";
			mlet	mne="eq";
		}
		strcmp	cmp=$(opr),"neq";
		if (cmp=0)
		{
			mlet	opr="!=";
			mlet	mne="ne";
		}
		strcmp	cmp=$(opr),"gte";
		if (cmp=0)
		{
			mlet	opr=">=";
			mlet	mne="ge";
		}
		strcmp	cmp=$(opr),"lte";
		if (cmp=0)
		{
			mlet	opr="<=";
			mlet	mne="le";
		}
		strcmp	cmp=$(opr),"gt";
		if (cmp=0)
		{
			mlet	opr=">";
			mlet	mne="gt";
		}
		strcmp	cmp=$(opr),"lt";
		if (cmp=0)
		{
			mlet	opr="<";
			mlet	mne="lt";
		}
		// error check
		strcmp	cmp=$(mne),"xxx";
		if (cmp=0)
		{
			// ERROR:
			errmsg	"logic_compare: unsupported operator ("$(opr)")";
			leave	stop_error;
		}
		check_param_lr	"logic_compare";
		mlet	do_blk_logic_compare=$(opr);

		// assembler
		fprint	fout,"// "$(lval)" "$(opr)" "$(rval);
		strcmp	cmp=$(opr),"==";
		if (cmp)
		{
			strcmp	cmp=$(opr),"!=";
		}
		if (cmp)
		{
			strcmp	cmp=$(opr),">=";
		}
		if (cmp)
		{
			strcmp	cmp=$(opr),"<";
		}
		if (cmp=0)
		{
			fprint	fout,$,;
			fprint	fout,"cmp"$,;
		}
		strcmp	cmp=$(opr),">";
		if (cmp=0)
		{
			mlet	opr="<";
			mlet	mne="lt";
			fprint	fout," ==> "$(rval)" "$(opr)" "$(lval)$,;
			fprint	fout,"swap"$,;
			fprint	fout,"cmp"$,;
		}
		strcmp	cmp=$(opr),"<=";
		if (cmp=0)
		{
			mlet	opr=">=";
			mlet	mne="ge";
			fprint	fout," ==> "$(rval)" "$(opr)" "$(lval)$,;
			fprint	fout,"swap"$,;
			fprint	fout,"cmp"$,;
		}
		asm_cjmp	$(mne),true;
		asm_bool;

		mlet	do_blk_logic_compare=$(lval)" "$(do_blk_logic_compare)" "
				$(rval);
	}
	procedure	do_blk_logic_operation
	{
		var		cmp;
		macro	opr;
		macro	lval;
		macro	rval;
		macro	mne;

		// assembler
		asm_label;
		macro	alab=$(asm_label);

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	opr=$(do_$(dxml));
					tolower		opr;
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"A";
					if (cmp=0)
					{
						mlet	lval=$(do_$(dxml));

						// operator
						mlet	mne="xxx";
						strcmp	cmp=$(opr),$(str_and);
						if (cmp=0)
						{
							mlet	mne="njmp";
						}
						strcmp	cmp=$(opr),$(str_or);
						if (cmp=0)
						{
							mlet	mne="cjmp";
						}

						// assembler
						fprint	fout,"dupl"$,;
						mlet	alab=$(alab)"_b"$(opr);
						fprint	fout,$(mne)"	"$(alab)$,;
					}
					else
					{
						mlet	rval=$(do_$(dxml));
					}
				}
			}
		}
		index	cmp=$(lval)," ";
		if (cmp>0)
		{
			mlet	lval="("$(lval)")";
		}
		index	cmp=$(rval)," ";
		if (cmp>0)
		{
			mlet	rval="("$(rval)")";
		}

		// operator
		mlet	mne="xxx";
		strcmp	cmp=$(opr),$(str_and);
		if (cmp=0)
		{
			mlet	mne=$(opr);
			mlet	opr="&&";
		}
		strcmp	cmp=$(opr),$(str_or);
		if (cmp=0)
		{
			mlet	mne=$(opr);
			mlet	opr="||";
		}
		mlet	do_blk_logic_operation=$(lval)" "$(opr)" "$(rval);

		// error check
		strcmp	cmp=$(mne),"xxx";
		if (cmp=0)
		{
			// ERROR:
			errmsg	"logic_operation: unsupported operator ("$(opr)")";
			leave	stop_error;
		}
		check_param_lr	"logic_operation";

		// assembler
		fprint	fout,"// "$(lval)" "$(opr)" "$(rval)$,;
		fprint	fout,$(mne)$,;
		fprint	fout,$(alab)":"$,;
	}
	procedure	do_blk_mcoc_text_label
	{
		var		cmp;
		macro	lnam;
		macro	cstr;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"NAME";
					if (cmp=0)
					{
						mlet	lnam=$(do_$(dxml));
					}
					else
					{
						mlet	cstr=$(do_$(dxml));
					}
				}
			}
		}
		strcmp	cmp=$(lnam),"";
		if (cmp=0)
		{
			// ERROR:
			errmsg	"mcoc_text_label: bad parameter";
			leave	stop_error;
		}

		// string constants
		psub	"^"$""([^"$""]*)"$""$","\1",cstr;
		gsub	"&lt;","<",cstr;
		gsub	"#","##",cstr;

		// search cstr in str_cnst#
		var		idx;
		idx=0;
		while (idx<n_str_cnst)
		{
			strcmp	cmp=$(str_cnst#(idx)),$(cstr);
			if (cmp=0)
			{
				break;
			}

			// continue
			idx=idx + 1;
		}
		if (idx<n_str_cnst)
		{
			// found same text
			strcat	str_lnam#(idx),$(lnam)":"$,;
		}
		else
		{
			// not found, unique text

			// register string constants
			labid=labid + 1;
			static : var	str_labl#(n_str_cnst)=-labid;
			static : macro	str_cnst#(n_str_cnst)=$(cstr);
			static : macro	str_lnam#(n_str_cnst)=$(lnam)":"$,;
			n_str_cnst=n_str_cnst + 1;
		}
	}
	procedure	do_blk_controls_repeat_ext
	{
		var		cmp;
		var		stat;
		macro	rcnt;

		// assembler
		asm_label;
		macro	alab=$(asm_label);
		macro	alab_loop=$(alab);
		fprint	fout,$,;
		fprint	fout,"// repeat loop"$,;
		fprint	fout,"// backup _rpt_cnt variable"$,;
		fprint	fout,"stw	[_rpt_cnt],"$(alab)"_rpt_cnt"$,;

		// register control variable
		register_vars	"_rpt_cnt";
		register_vars	$(alab)"_rpt_cnt";

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			if (stat=0)
			{
				pindex	cmp=$(cxml),"^<statement[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^<next[ >]";
				}
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// loop condition

					// assembler
					fprint	fout,"// _rpt_cnt="$(rcnt)$,;
					fprint	fout,"stw	_rpt_cnt"$,;
					fprint	fout,"// repeat ("$(rcnt)")"$,;
					fprint	fout,$(alab)"_repeat:"$,;
					fprint	fout,"// _rpt_cnt<1 ?"$,;
					fprint	fout,"cmp	[_rpt_cnt],1"$,;
					asm_cjmp	"lt";
					fprint	fout,$(asm_cjmp)"	"$(alab)"_break"$,;

					// continue
					pindex	cmp=$(cxml),"^<statement[ >]";
					if (cmp>0)
					{
						stat=1;
						continue;
					}
					else
					{
						// empty block
						stat=2;
					}
				}
			}
			if (stat=1)
			{
				// loop block
				pindex	cmp=$(cxml),"^</statement[ >]";
				if (cmp>0)
				{
					// end of loop
					stat=2;
					continue;
				}
			}
			if (stat=2)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// end of loop

					// assembler
					fprint	fout,$,;
					fprint	fout,"// end of repeat loop"$,;
					fprint	fout,$(alab)"_continue:"$,;
					fprint	fout,"sub	[_rpt_cnt],1"$,;
					fprint	fout,"dupl"$,;
					fprint	fout,"stw	_rpt_cnt"$,;
					fprint	fout,"cjmp	"$(alab)"_repeat"$,;
					fprint	fout,$,;
					fprint	fout,$(alab)"_break:"$,;
					fprint	fout,"// restore _rpt_cnt variable"$,;
					fprint	fout,"stw	["$(alab)"_rpt_cnt],_rpt_cnt"$,;
					mlet	alab_loop="_auto_0000";

					break;
				}
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				if (stat=0)
				{
					strcmp	cmp=$(dxml),"value";
					if (cmp=0)
					{
						mlet	rcnt=$(do_$(dxml));
					}
				}
			}
		}
	}
	procedure	do_blk_controls_whileUntil
	{
		var		cmp;
		var		stat;
		macro	wexp;
		macro	wmod=$(str_whl);

		// assembler
		asm_label;
		macro	alab=$(asm_label);
		macro	alab_loop=$(alab);
		fprint	fout,$,;
		fprint	fout,"// while/until loop"$,;
		fprint	fout,$(alab)"_while:"$,;
		fprint	fout,$(alab)"_continue:"$,;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			if (stat=0)
			{
				pindex	cmp=$(cxml),"^<statement[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^<next[ >]";
				}
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// loop condition

					// assembler
					fprint	fout,"// "$(wmod)" ("$(wexp)")"$,;
					strcmp	cmp=$(wmod),"until";
					if (cmp)
					{
						// while
						fprint	fout,"njmp	"$(alab)"_break"$,;
					}
					else
					{
						// until
						fprint	fout,"cjmp	"$(alab)"_break"$,;
					}

					// continue
					pindex	cmp=$(cxml),"^<statement[ >]";
					if (cmp>0)
					{
						stat=1;
						continue;
					}
					else
					{
						// empty block
						stat=2;
					}
				}
			}
			if (stat=1)
			{
				// loop block
				pindex	cmp=$(cxml),"^</statement[ >]";
				if (cmp>0)
				{
					// end of loop block
					stat=2;
					continue;
				}
			}
			if (stat=2)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// end of loop

					// assembler
					fprint	fout,$,;
					fprint	fout,"// end of "$(wmod)" loop"$,;
					fprint	fout,"jmp	"$(alab)"_while"$,;
					fprint	fout,$,;
					fprint	fout,$(alab)"_break:"$,;
					mlet	alab_loop="_auto_0000";

					break;
				}
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				if (stat=0)
				{
					strcmp	cmp=$(dxml),"field";
					if (cmp=0)
					{
						mlet	wmod=$(do_$(dxml));
						tolower		wmod;
					}
					strcmp	cmp=$(dxml),"value";
					if (cmp=0)
					{
						mlet	wexp=$(do_$(dxml));
					}
				}
			}
		}
	}
	procedure	do_blk_controls_flow_statements
	{
		var		cmp;
		macro	flws;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	flws=$(do_$(dxml));
				}
			}
		}
		tolower		flws;

		// assembler
		fprint	fout,"// "$(flws)$,;
		fprint	fout,"jmp	"$(alab_loop)"_"$(flws)$,;
	}
	procedure	do_blk_controls_if
	{
		var		idx;
		var		cmp;
		var		stat;
		var		cnt_elif;
		var		cnt_else;
		macro	cexp;

		// assembler
		asm_label;
		macro	alab=$(asm_label);
		fprint	fout,$,;
		fprint	fout,"// if statement"$,;

		// if
		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			if (stat=0)
			{
				pindex	cmp=$(cxml),"^<statement[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^<next[ >]";
				}
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// if condition
					static : analyze_xml	$(cxml);
					nmacro	_xml_name;
					strcmp	cmp=$(_xml_name),"DO0";
					if (cmp)
					{
						// ERROR:
						errmsg	"controls_if: inhibited empty if block";
						leave	stop_error;
					}
					strcmp	cmp=$(cexp),"";
					if (cmp=0)
					{
						// ERROR:
						errmsg	"controls_if: if condition not found";
						leave	stop_error;
					}

					// assembler
					fprint	fout,"// if ("$(cexp)")"$,;
					fprint	fout,"njmp	"$(alab)"_if0"$,;

					// continue
					pindex	cmp=$(cxml),"^<statement[ >]";
					if (cmp>0)
					{
						stat=1;
						continue;
					}
					else
					{
						// ERROR:
						errmsg	"controls_if: inhibited empty if block";
						leave	stop_error;
					}
				}
			}
			if (stat=1)
			{
				// if block
				pindex	cmp=$(cxml),"^</statement[ >]";
				if (cmp>0)
				{
					// end of if block

					// assembler
					fprint	fout,$,;
					fprint	fout,"// end of if block"$,;
					fprint	fout,"jmp	"$(alab)"_endif"$,;
					fprint	fout,$,;
					fprint	fout,$(alab)"_if0:"$,;

					break;
				}
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				if (stat=0)
				{
					// mutation must be processed before calling do_$(dxml)
					strcmp	cmp=$(dxml),"mutation";
					if (cmp=0)
					{
						nmacro	_xml_elseif="0";
						nmacro	_xml_else="0";
						cnt_elif=$(_xml_elseif);
						cnt_else=$(_xml_else);
					}
				}
				do_$(dxml);
				if (stat=0)
				{
					strcmp	cmp=$(dxml),"value";
					if (cmp=0)
					{
						mlet	cexp=$(do_$(dxml));
					}
				}
			}
		}

		// elif
		idx=1;
		while (idx<=cnt_elif)
		{
			stat=0;
			mlet	cexp="";
			while (true)
			{
				fget_xml;
				macro	cxml=$(fget_xml);
				if (stat=0)
				{
					pindex	cmp=$(cxml),"^<statement[ >]";
					if (cmp<=0)
					{
						pindex	cmp=$(cxml),"^<next[ >]";
					}
					if (cmp<=0)
					{
						pindex	cmp=$(cxml),"^</block[ >]";
					}
					if (cmp>0)
					{
						// elif condition
						static : analyze_xml	$(cxml);
						strcmp	cmp=$(_xml_name),"DO"#(idx);
						if (cmp)
						{
							// ERROR:
							errmsg	"controls_if: inhibited empty elif# block",
									idx;
							leave	stop_error;
						}
						strcmp	cmp=$(cexp),"";
						if (cmp=0)
						{
							// ERROR:
							errmsg	"controls_if: elif# condition not found",
									idx;
							leave	stop_error;
						}

						// assembler
						fprint	fout,"// elif# ("$(cexp)")"$,,idx;
						fprint	fout,"njmp	"$(alab)"_elif#"$,,idx;

						// continue
						pindex	cmp=$(cxml),"^<statement[ >]";
						if (cmp>0)
						{
							stat=1;
							continue;
						}
						else
						{
							// ERROR:
							errmsg	"controls_if: inhibited empty elif# block",
									idx;
							leave	stop_error;
						}
					}
				}
				if (stat=1)
				{
					// elif block
					pindex	cmp=$(cxml),"^</statement[ >]";
					if (cmp>0)
					{
						// end of elif block

						// assembler
						fprint	fout,$,;
						fprint	fout,"// end of elif# block"$,,idx;
						fprint	fout,"jmp	"$(alab)"_endif"$,;
						fprint	fout,$,;
						fprint	fout,$(alab)"_elif#:"$,,idx;

						break;
					}
				}

				pindex	cmp=$(cxml),"^<[^/]";
				if (cmp>0)
				{
					static : analyze_xml	$(cxml);
					macro	dxml=$(_xml_);
					do_$(dxml);
					if (stat=0)
					{
						strcmp	cmp=$(dxml),"value";
						if (cmp=0)
						{
							mlet	cexp=$(do_$(dxml));
						}
					}
				}
			}

			// continue
			idx=idx + 1;
		}

		// else
		if (cnt_else>0)
		{
			stat=0;
			while (true)
			{
				fget_xml;
				macro	cxml=$(fget_xml);
				if (stat=0)
				{
					pindex	cmp=$(cxml),"^<statement[ >]";
					if (cmp<=0)
					{
						pindex	cmp=$(cxml),"^<next[ >]";
					}
					if (cmp<=0)
					{
						pindex	cmp=$(cxml),"^</block[ >]";
					}
					if (cmp>0)
					{
						// else
						static : analyze_xml	$(cxml);
						strcmp	cmp=$(_xml_name),"ELSE";
						if (cmp)
						{
							// ERROR:
							errmsg	"controls_if: inhibited empty else block";
							leave	stop_error;
						}

						// assembler
						fprint	fout,$,;
						fprint	fout,"// else"$,;

						// continue
						pindex	cmp=$(cxml),"^<statement[ >]";
						if (cmp>0)
						{
							stat=1;
							continue;
						}
						else
						{
							// ERROR:
							errmsg	"controls_if: inhibited empty else block.";
							leave	stop_error;
						}
					}
				}
				if (stat=1)
				{
					// else block
					pindex	cmp=$(cxml),"^</statement[ >]";
					if (cmp>0)
					{
						// end of else block

						// assembler
						fprint	fout,$,;
						fprint	fout,"// end of else block"$,;

						break;
					}
				}

				pindex	cmp=$(cxml),"^<[^/]";
				if (cmp>0)
				{
					static : analyze_xml	$(cxml);
					macro	dxml=$(_xml_);
					do_$(dxml);
				}
			}
		}
		skip_one	"block";

		// assembler
		fprint	fout,$,;
		fprint	fout,"// endif"$,;
		fprint	fout,$(alab)"_endif:"$,;
	}
	procedure	do_blk_mcoc_controls_forc
	{
		var		cmp;
		var		stat;
		macro	vnam;
		macro	nfrm;
		macro	wexp;
		macro	nwth;

		// assembler
		asm_label;
		macro	alab=$(asm_label);
		macro	alab_loop=$(alab);
		fprint	fout,$,;
		fprint	fout,"// for-c loop"$,;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			if (stat=0)
			{
				pindex	cmp=$(cxml),"^<statement[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^<next[ >]";
				}
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// continue
					pindex	cmp=$(cxml),"^<statement[ >]";
					if (cmp>0)
					{
						stat=1;
						continue;
					}
					else
					{
						// empty block
						stat=2;
					}
				}
			}
			if (stat=1)
			{
				// loop block
				pindex	cmp=$(cxml),"^</statement[ >]";
				if (cmp>0)
				{
					// end of loop block
					stat=2;
					continue;
				}
			}
			if (stat=2)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// end of loop
					break;
				}
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				if (stat=0)
				{
					strcmp	cmp=$(dxml),"field";
					if (cmp=0)
					{
						mlet	vnam=$(do_$(dxml));
					}
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"FROM";
					if (cmp=0)
					{
						mlet	nfrm=$(do_$(dxml));

						// assembler
						fprint	fout,"// "$(vnam)"="$(nfrm)$,;
						fprint	fout,"stw	"$(vnam)$,;
						fprint	fout,$,;
						fprint	fout,"// for-c while "$,;
						fprint	fout,$(alab)"_forc:"$,;
					}
					strcmp	cmp=$(dnam),"BOOL";
					if (cmp=0)
					{
						// loop condition
						mlet	wexp=$(do_$(dxml));

						// assembler
						fprint	fout,"// while ("$(wexp)")"$,;
						fprint	fout,"cjmp	"$(alab)"_block"$,;
						fprint	fout,"jmp	"$(alab)"_break"$,;
						fprint	fout,$,;
						fprint	fout,"// for-c with"$,;
						fprint	fout,$(alab)"_continue:"$,;
					}
					strcmp	cmp=$(dnam),"WITH";
					if (cmp=0)
					{
						mlet	nwth=$(do_$(dxml));

						// assembler
						fprint	fout,"// "$(vnam)"="$(nwth)$,;
						fprint	fout,"stw	"$(vnam)$,;
						fprint	fout,"jmp	"$(alab)"_forc"$,;
						fprint	fout,$,;
						fprint	fout,"// for-c block"$,;
						fprint	fout,$(alab)"_block:"$,;
					}
				}
			}
		}
		strcmp	cmp=$(nfrm),"";
		if (cmp)
		{
			strcmp	cmp=$(wexp),"";
		}
		if (cmp)
		{
			strcmp	cmp=$(nwth),"";
		}
		if (cmp=0)
		{
			// ERROR:
			errmsg	"mcoc_controls_forc: empty parameter";
			leave	stop_error;
		}

		// assembler
		fprint	fout,$,;
		fprint	fout,"// end of for-c loop"$,;
		fprint	fout,"jmp	"$(alab)"_continue"$,;
		fprint	fout,$(alab)"_break:"$,;
	}
	procedure	do_blk_mcoc_controls_dorept
	{
		var		cmp;
		var		stat;
		macro	wexp;
		macro	wmod=$(str_whl);

		// assembler
		asm_label;
		macro	alab=$(asm_label);
		macro	alab_loop=$(alab);
		fprint	fout,$,;
		fprint	fout,"// do while/until loop"$,;
		fprint	fout,$(alab)"_dorep:"$,;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			if (stat=0)
			{
				pindex	cmp=$(cxml),"^<statement[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^<next[ >]";
				}
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// continue
					pindex	cmp=$(cxml),"^<statement[ >]";
					if (cmp>0)
					{
						// assembler
						fprint	fout,"// do block"$,;

						stat=1;
						continue;
					}
					else
					{
						// empty block
						stat=2;
					}
				}
			}
			if (stat=1)
			{
				// loop block
				pindex	cmp=$(cxml),"^</statement[ >]";
				if (cmp>0)
				{
					// end of loop block
					stat=2;
					continue;
				}
			}
			if (stat=2)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// end of loop
					break;
				}
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					// end of do repeat
					if (stat=0)
					{
						// empty block

						// assembler
						fprint	fout,"// do block"$,;
					}

					// assembler
					fprint	fout,$,;
					fprint	fout,"// end of do "$(wmod)" loop"$,;
					fprint	fout,$(alab)"_continue:"$,;
				}
				do_$(dxml);
				if (stat=0)
				{
					strcmp	cmp=$(dxml),"field";
					if (cmp=0)
					{
						mlet	wmod=$(do_$(dxml));
						tolower		wmod;
					}
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					// loop condition
					mlet	wexp=$(do_$(dxml));

					// assembler
					fprint	fout,"// "$(wmod)" ("$(wexp)")"$,;
					strcmp	cmp=$(wmod),"until";
					if (cmp)
					{
						// while
						fprint	fout,"cjmp	"$(alab)"_dorep"$,;
					}
					else
					{
						// until
						fprint	fout,"njmp	"$(alab)"_dorep"$,;
					}
					fprint	fout,$,;
					fprint	fout,$(alab)"_break:"$,;
					mlet	alab_loop="_auto_0000";
				}
			}
		}
		strcmp	cmp=$(wexp),"";
		if (cmp=0)
		{
			// ERROR:
			errmsg	"controls_dorept: empty condition";
			leave	stop_error;
		}
	}
	procedure	do_blk_mcoc_controls_loop
	{
		var		cmp;
		var		stat;
		macro	wexp;

		// assembler
		asm_label;
		macro	alab=$(asm_label);
		macro	alab_loop=$(alab);
		fprint	fout,$,;
		fprint	fout,"// forever loop"$,;
		fprint	fout,$(alab)"_loop:"$,;
		fprint	fout,$(alab)"_continue:"$,;
		fprint	fout,$(alab)"_break:"$,;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			if (stat=0)
			{
				pindex	cmp=$(cxml),"^<statement[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^<next[ >]";
				}
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// loop condition

					// assembler
					fprint	fout,"// loop"$,;

					// continue
					pindex	cmp=$(cxml),"^<statement[ >]";
					if (cmp>0)
					{
						stat=1;
						continue;
					}
					else
					{
						// empty block
						stat=2;
					}
				}
			}
			if (stat=1)
			{
				// loop block
				pindex	cmp=$(cxml),"^</statement[ >]";
				if (cmp>0)
				{
					// end of loop block
					stat=2;
					continue;
				}
			}
			if (stat=2)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// end of loop

					// assembler
					fprint	fout,$,;
					fprint	fout,"// end of forever loop"$,;
					fprint	fout,"jmp	"$(alab)"_loop"$,;
					mlet	alab_loop="_auto_0000";

					break;
				}
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
			}
		}
	}
	procedure	do_blk_procedures_ifreturn
	{
		var		cmp;
		macro	cexp;
		macro	vrtn;

		// assembler
		asm_label;
		macro	alab=$(asm_label);
		fprint	fout,$,;
		fprint	fout,"// if return"$,;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"CONDITION";
					if (cmp=0)
					{
						mlet	cexp=$(do_$(dxml));

						// assembler
						fprint	fout,"// if ("$(cexp)")"$,;
						fprint	fout,"njmp	"$(alab)"_endif"$,;
					}
					strcmp	cmp=$(dnam),"VALUE";
					if (cmp=0)
					{
						mlet	vrtn=$(do_$(dxml));
					}
				}
			}
		}

		// assembler
		strcmp	cmp=$(vrtn),"";
		if (cmp)
		{
			fprint	fout,"// return ("$(vrtn)")"$,;
			fprint	fout,"swap"$,;
		}
		else
		{
			fprint	fout,"// return"$,;
		}
		fprint	fout,"rtn"$,;
		fprint	fout,$,;
		fprint	fout,$(alab)"_endif:"$,;
	}
	procedure	do_blk_procedures_defreturn
	{
		var		cmp;
		var		stat;
		macro	fnam;
		macro	muta;
		macro	vrtn;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			if (stat=0)
			{
				pindex	cmp=$(cxml),"^<statement[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^<next[ >]";
				}
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// continue
					pindex	cmp=$(cxml),"^<statement[ >]";
					if (cmp>0)
					{
						stat=1;
						continue;
					}
					else
					{
						// empty block
						stat=2;
					}
				}
			}
			if (stat=1)
			{
				// function block
				pindex	cmp=$(cxml),"^</statement[ >]";
				if (cmp>0)
				{
					// end of procedure/function
					stat=2;
					fprint	fout,$,;
					fprint	fout,"// end of procedure/function: "$(fnam)$,;
					continue;
				}
			}
			if (stat=2)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// end of procedure/function

					// assembler
					strcmp	cmp=$(vrtn),"";
					if (cmp)
					{
						fprint	fout,"// return ("$(vrtn)")"$,;
						fprint	fout,"swap"$,;
					}
					fprint	fout,"rtn"$,;

					break;
				}
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				if (stat=0)
				{
					strcmp	cmp=$(dxml),"mutation";
					if (cmp=0)
					{
						mlet	muta=$(do_$(dxml));
					}
					strcmp	cmp=$(dxml),"field";
					if (cmp=0)
					{
						mlet	fnam=$(do_$(dxml));

						// assembler
						if (defp_1st)
						{
							defp_1st=false;
							fprint	fout,$,;
							fprint	fout,"// halt"$,;
							fprint	fout,"jmp	_rtlb_prog_halt"$,;
						}
						fprint	fout,$,;
						fprint	fout,"// procedure/function: "$(fnam);
						strcmp	cmp=$(muta),"";
						if (cmp)
						{
							psub	" $","",muta;
							pgsub	" ",", ",muta;
							fprint	fout," ("$(muta)")";
						}
						fprint	fout,$,;
						fprint	fout,$(fnam)":"$,;
					}
				}
				if (true | stat=2)
				{
					strcmp	cmp=$(dxml),"value";
					if (cmp=0)
					{
						mlet	vrtn=$(do_$(dxml));
					}
				}
			}
		}
	}
	procedure	do_blk_procedures_defnoreturn
	{
		do_blk_procedures_defreturn;
	}
	procedure	do_blk_procedures_callreturn
	{
		var		cmp;
		macro	fnam;
		macro	muta;

		// assembler
		fprint	fout,"// call procedure/function"$,;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"mutation";
				if (cmp=0)
				{
					mlet	fnam=$(dnam);
					mlet	muta=$(do_$(dxml));
					psub	" $","",muta;
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					var		num;
					var		narg;

					field	num=muta;
					psub	"[^0-9]*([0-9]+).*","\1",dnam;
					narg=$(dnam) + 1;

					// assembler
					fprint	fout,"// "$(muta#(narg))"="$(do_$(dxml))$,;
					fprint	fout,"stw	"$(muta#(narg))$,;
				}
			}
		}

		// assembler
		fprint	fout,"// function call: "$(fnam)" ()"$,;
		fprint	fout,"jal	"$(fnam)$,;

		mlet	do_blk_procedures_callreturn=$(fnam)" ()";
	}
	procedure	do_blk_procedures_callnoreturn
	{
		do_blk_procedures_callreturn;
	}
	procedure	do_block
	{
		var		cmp;

		nmacro	_xml_disabled="";
		strcmp	cmp=$(_xml_disabled),"true";
		if (cmp=0)
		{
			fget_xml;
			pindex	cmp=$(fget_xml),"^<next[ >]";
			if (cmp>0)
			{
				return;
			}
			repeat
			{
				skip_one	"block";
				pindex	cmp=$(fget_xml),"^<next[ >]";
			} until (cmp<=0);
		}
		else
		{
			// block type
			macro	blktyp=$(_xml_type);
//fprint	fout,"##@		"$(blktyp)$,;
			do_blk_$(blktyp);
			mlet	do_block=$(do_blk_$(blktyp));
		}
	}
	procedure	do_xml
	{
		var		cmp;

		fget_xml;
		while (fget_xml>=0)
		{
			static : analyze_xml	$(fget_xml);
			if (!analyze_xml)
			{
				// continue
				fget_xml;
				continue;
			}
			strcmp	cmp=$(_xml_),"";
			if (cmp)
			{
				strcmp	cmp=$(_xml_),"/",left;
			}
			if (cmp)
			{
				strcmp	cmp=$(_xml_),"next";
			}
			if (cmp=0)
			{
				// continue
				fget_xml;
				continue;
			}

			pindex	cmp=$(fget_xml),"^<";
			if (true & cmp>0)
			{
				do_$(_xml_);
			}

			// continue
			fget_xml;
		}
	}


	// open input file
	var		fin;
	fopen	fin,$(fnam_in),"r";

	// input file size
	var		fpos;
	var		fsiz;
	fseek	fin,-1;
	ftell	fin,fsiz;
	fseek	fin,0;
	if (fsiz=0)
	{
		// ERROR:
		errmsg	"Empty XML file";
		leave	stop_error;
	}

	// open output file
	var		fout;
	fopen	fout,$(fnam_out),"w";

	// assembler
	fprint	fout,"// "$(prog_name)" ver."$(prog_vers)$,;
	fprint	fout,"## assembler"$,;
	fprint	fout,"asm	"$""mcoc_irom.mem"$"$,;
	fprint	fout,"incl	"$""mcoc115.incl"$"$,;
	fprint	fout,"## constants"$,;
	fprint	fout,"equ	_rtlb_fpu_need,@fpu_need@"$,;
	fprint	fout,"##@equs_def@"$,;
	fprint	fout,"##@vars_def@"$,;
	fprint	fout,$,;
	fprint	fout,"## include run time library"$,;
	fprint	fout,"incl	"$"$(mynam)".incl"$"$,;
	fprint	fout,"##@incl_lib@"$,;
	fprint	fout,$,;
	fprint	fout,"// ================================"$,;
	fprint	fout,"// _rtlb_main: start user program code"$,;
	fprint	fout,"// ================================"$,;
	fprint	fout,"_rtlb_main:"$,;
	fprint	fout,$,;

	do_xml;
	progress	"",-1;

	// assembler
	if (defp_1st)
	{
		defp_1st=false;
		fprint	fout,$,;
		fprint	fout,"// halt"$,;
		fprint	fout,"jmp	_rtlb_prog_halt"$,;
	}
	define_aryv;
	fprint	fout,$,;
	fprint	fout,"// task entry point"$,;
	fprint	fout,"align	2"$,;
	fprint	fout,"_rtlb_cpu2:"$,;
	if (tsk_def_cpu2)
	{
		fprint	fout,"datw	lab__rtlb_task_cpu2"$,;
	}
	else
	{
		fprint	fout,"datw	_rtlb_null"$,;
	}
	fprint	fout,"_rtlb_poly:"$,;
	if (tsk_def_poly)
	{
		fprint	fout,"datw	lab__rtlb_task_poly"$,;
	}
	else
	{
		fprint	fout,"datw	_rtlb_null"$,;
	}
	fprint	fout,"_rtlb_irq:"$,;
	if (tsk_def_irq)
	{
		fprint	fout,"datw	lab__rtlb_task_irq"$,;
	}
	else
	{
		fprint	fout,"datw	_rtlb_null"$,;
	}
	fprint	fout,"_rtlb_irq2:"$,;
	if (tsk_def_irq2)
	{
		fprint	fout,"datw	lab__rtlb_task_irq2"$,;
	}
	else
	{
		fprint	fout,"datw	_rtlb_null"$,;
	}
	fprint	fout,"_rtlb_irqp:"$,;
	if (tsk_def_irqp)
	{
		fprint	fout,"datw	lab__rtlb_task_irqp"$,;
	}
	else
	{
		fprint	fout,"datw	_rtlb_null"$,;
	}

	// define string constants
	if (n_str_cnst>0)
	{
		var		idx;

		// assembler
		fprint	fout,$,;
		fprint	fout,"// string constants"$,;
		fprint	fout,"_rtlb_strc_top:"$,;

		idx=0;
		while (idx<n_str_cnst)
		{
			// assembler
			macro	alab;
			num2str		alab=abs (str_labl#(idx)),"%04x";
			fprint	fout,"_auto_"$(alab)"_text:"$,;
			fprint	fout,$(str_lnam#(idx));
			fprint	fout,"dats	"$"$(str_cnst#(idx))"\0"$"$,;

			// continue
			idx=idx + 1;
		}

		// assembler
		fprint	fout,"_rtlb_strc_bottom:"$,;
	}

	// close files
	fclose	fin;
	fclose	fout;


	// translator options

	// run time library variables
	if (true)
	{
		var		idx=0;
		while ($(lib_vars#(idx))>=0)
		{
			if ($(lib_vars#(idx))=0 |
				($(lib_vars#(idx))=1 & need_stnd)
				)
			{
				register_vars	$(lib_vars#(idx + 1));
			}

			// continue
			idx=idx + 2;
		}
	}

	// embed variable definitions
	fopen	fin,$(fnam_out),"r";
	fopen	fout,$(fnam_tmp),"w";

	fgets	fin,lbuf;
	while (status=0)
	{
		var		cmp;

		pindex	cmp=$(lbuf),"^#@equs_def@$";
		if (cmp>0)
		{
			var		idx;

			// user equations
			if (elst_cnt>0)
			{
				idx=0;
				while (idx<elst_cnt)
				{
					// assembler
					fputl	fout,$(elst_equ#(idx));

					// continue
					idx=idx + 1;
				}
			}

			// continue
			fgets	fin,lbuf;
			continue;
		}
		pindex	cmp=$(lbuf),"^#@vars_def@$";
		if (cmp>0)
		{
			var		idx;
			var		num;

			// assembler
			fprint	fout,$,;
			fprint	fout,"## define variables"$,;
			fprint	fout,"equ	_rtlb_var_sizw,2"$,;
			fprint	fout,"equ	_rtlb_var_sftw,1"$,;
			fprint	fout,"equ	_va,iramtop"$,;
			fprint	fout,"equ	_rtlb_var_top,_va"$,;

			psub	"^@","",vlst_vars;
			field	num=vlst_vars,"@";
			idx=1;
			while (idx<num)
			{
				// assembler
				fprint	fout,"equ	"$(vlst_vars#(idx))",_va"$,;
				fprint	fout,"equ	_va,_va+_rtlb_var_sizw"$,;

				// continue
				idx=idx + 1;
			}

			// assembler
			fprint	fout,"## end of define variables"$,;
			fprint	fout,"equ	_rtlb_var_static,_va"$,;
			if (alst_cnt>0)
			{
				var		idx;

				fprint	fout,$,;
				fprint	fout,"## define allocation buffers"$,;
				while (idx<alst_cnt)
				{
					fprint	fout,"equ	_va,(_va+_rtlb_var_sizw-1)/"
							"_rtlb_var_sizw*_rtlb_var_sizw	// align"$,;
					fprint	fout,"equ	"$(alst_lnam_#(idx))",_va"$,;
					fprint	fout,"equ	_va,_va+("$(alst_asiz_#(idx))")"$,;

					// continue
					idx=idx + 1;
				}
				fprint	fout,"## end of define allocation buffers"$,;
				fprint	fout,"equ	_rtlb_var_alloc,_va"$,;
			}
			fprint	fout,"equ	_rtlb_var_array,_va"$,;

			// continue
			fgets	fin,lbuf;
			continue;
		}
		pindex	cmp=$(lbuf),"^#@incl_lib@$";
		if (cmp>0)
		{
			if (need_stnd)
			{
// not implemented yet
fprint	fout,"//incl	"$"$(mynam)"_libstnd$(z).incl"$"$,;
			}

			// continue
			fgets	fin,lbuf;
			continue;
		}

		sub		"@fpu_need@",$(str_bool#(opt_fpu_need)),lbuf;
		fputl	fout,$(lbuf);

		// continue
		fgets	fin,lbuf;
	}

	// assembler
	fprint	fout,$,;
	fprint	fout,"// program size / variable area size"$,;
	fprint	fout,"align	2"$,;
	fprint	fout,"_rtlb_prog_size:"$,;
	fprint	fout,"datw	lab__rtlb_prog_bottom"$,;
	fprint	fout,"// array buffer (bottom address)"$,;
	fprint	fout,"datw	_rtlb_var_array"$,;
	fprint	fout,"// string buffer (bottom address)"$,;
	fprint	fout,"datw	_rtlb_null"$,;
	fprint	fout,"// static variables (bottom address)"$,;
	fprint	fout,"datw	_rtlb_var_static"$,;
	fprint	fout,"// run time library version"$,;
	fprint	fout,"datw	_rtlb_vers"$,;
	fprint	fout,"_rtlb_prog_bottom:"$,;

	// close files
	fclose	fin;
	fclose	fout;

	// replace output file
	fmove	$(fnam_tmp),$(fnam_out), force;


	leave	stop_error;
}

