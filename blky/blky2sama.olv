	procedure	do_blk_mcoc_matf_array_set
	{
		var		cmp;
		macro	vnam;
		macro	nidx;
		macro	nval;

		// assembler
		fprint	fout,"// array set"$,;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	vnam=$(do_$(dxml));
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"IDX";
					if (cmp=0)
					{
						mlet	nidx=$(do_$(dxml));
					}
					strcmp	cmp=$(dnam),"VAL";
					if (cmp=0)
					{
						mlet	nval=$(do_$(dxml));
					}
				}
			}
		}

		// assembler
		fprint	fout,"// "$(vnam)"["$(nidx)"]="$(nval)$,;
		fprint	fout,"swap"$,;
		fprint	fout,"asl"$,;
		fprint	fout,"add	["$(vnam)"]"$,;
		fprint	fout,"stw"$,;
	}
	procedure	do_blk_mcoc_matf_arithmetic
	{
		var		cmp;
		macro	opr;
		macro	lval;
		macro	rval;
		macro	mne;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	opr=$(do_$(dxml));
					tolower		opr;
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"A";
					if (cmp)
					{
						strcmp	cmp=$(dnam),"VAR1";
					}
					if (cmp=0)
					{
						mlet	lval=$(do_$(dxml));
					}
					else
					{
						mlet	rval=$(do_$(dxml));
					}
				}
			}
		}
		tolower		opr;
		index	cmp=$(lval)," ";
		if (cmp>0)
		{
			mlet	lval="("$(lval)")";
		}
		index	cmp=$(rval)," ";
		if (cmp>0)
		{
			mlet	rval="("$(rval)")";
		}

		// operator
		mlet	mne="xxx";
		strcmp	cmp=$(opr),"add";
		if (cmp)
		{
			strcmp	cmp=$(opr),"+";
		}
		if (cmp=0)
		{
			mlet	opr="+";
			mlet	mne="fadd";
		}
		strcmp	cmp=$(opr),"minus";
		if (cmp)
		{
			strcmp	cmp=$(opr),"-";
		}
		if (cmp=0)
		{
			mlet	opr="-";
			mlet	mne="fsub";
		}
		strcmp	cmp=$(opr),"multiply";
		if (cmp)
		{
			strcmp	cmp=$(opr),"*";
		}
		if (cmp=0)
		{
			mlet	opr="*";
			mlet	mne="fmul";
		}
		strcmp	cmp=$(opr),"divide";
		if (cmp)
		{
			strcmp	cmp=$(opr),"/";
		}
		if (cmp=0)
		{
			mlet	opr="/";
			mlet	mne="fdiv";
		}

		// error check
		strcmp	cmp=$(mne),"xxx";
		if (cmp=0)
		{
			// ERROR:
			errmsg	"mcoc_matf_arithmetic: unsupported operator ("$(opr)")";
			leave	stop_error;
		}
		check_param_lr	"mcoc_matf_arithmetic";

		// assembler
		fprint	fout,"// "$(lval)" "$(opr)" "$(rval)$,;
		fprint	fout,$(mne)$,;

		mlet	do_blk_mcoc_matf_arithmetic=$(lval)" "$(opr)" "$(rval);
		opt_fpu_need=true;
	}
	procedure	do_blk_mcoc_matf_binary
	{
		var		cmp;
		macro	opr;
		macro	lval;
		macro	rval;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	opr=$(do_$(dxml));
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"data";
					if (cmp)
					{
						strcmp	cmp=$(dnam),"A";
					}
					if (cmp=0)
					{
						mlet	lval=$(do_$(dxml));
					}
					else
					{
						mlet	rval=$(do_$(dxml));
					}
				}
			}
		}
		tolower		opr;
		strcmp	cmp=$(opr),"power";
		if (cmp=0)
		{
			mlet	opr="**";
		}
		strcmp	cmp=$(opr),"modulo";
		if (cmp=0)
		{
			mlet	opr="%";
		}
		index	cmp=$(lval)," ";
		if (cmp>0)
		{
			mlet	lval="("$(lval)")";
		}
		index	cmp=$(rval)," ";
		if (cmp>0)
		{
			mlet	rval="("$(rval)")";
		}
		mlet	do_blk_mcoc_matf_binary=$(lval)" "$(opr)" "$(rval);
		opt_fpu_need=true;

		// assembler
		fprint	fout,"// "$(lval)" "$(opr)" "$(rval)$,;

		// operator
		strcmp	cmp=$(opr),"modulo";
		if (cmp)
		{
			strcmp	cmp=$(opr),"%";
		}
		if (cmp=0)
		{
			// modulo operator
			mlet	opr="";

			// assembler
//	%%%%%%%%%%%%%%%%	blky2sama_math.incl
			fprint	fout,"// A%B=A - trunc (A/B)*B"$,;
			fprint	fout,"stw	_r0"$,;		// A
			fprint	fout,"dupl"$,;			// A,A
			fprint	fout,"fdiv	[_r0]"$,;	// A,A/B
			fprint	fout,"ftrunc	0"$,;	// A,trunc(A/B)
			fprint	fout,"fmul	[_r0]"$,;	// A,trunc(A/B)*B
			fprint	fout,"fsub"$,;			// A-trunc(A/B)*B
		}
		strcmp	cmp=$(opr),"min";
		if (cmp)
		{
			strcmp	cmp=$(opr),"max";
		}
		if (cmp=0)
		{
			// minimum / maximum operator
			mlet	opr="";

			// assembler
			fprint	fout,"stw	_r0"$,;				// A
			fprint	fout,"dupl"$,;					// A,A
			fprint	fout,"fcmp	[_r0]"$,;			// A,NCVZ(A-B)
			fprint	fout,"and	sama_hcmp_nf"$,;	// A,N(A<B)
			asm_label;
			strcmp	cmp=$(opr),"min";
			if (cmp=0)
			{
				fprint	fout,"cjmp	"$(asm_label)$,;	// A
			}
			else
			{
				fprint	fout,"njmp	"$(asm_label)$,;	// A
			}
			fprint	fout,"pop"$,;
			fprint	fout,"ldw	_r0"$,;					// B
			fprint	fout,$(asm_label)":"$,;
		}

		// error check
		strcmp	cmp=$(opr),"";
		if (cmp)
		{
			// ERROR:
			errmsg	"mcoc_matf_binary: not supported operator ("$(opr)")";
			leave	stop_error;
		}
		check_param_lr	"mcoc_matf_binary";
	}
	procedure	do_blk_mcoc_matf_compare
	{
		var		cmp;
		macro	opr;
		macro	lval;
		macro	rval;
		macro	mne;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	opr=$(do_$(dxml));
					tolower		opr;
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"A";
					if (cmp=0)
					{
						mlet	lval=$(do_$(dxml));
					}
					else
					{
						mlet	rval=$(do_$(dxml));
					}
				}
			}
		}
		index	cmp=$(lval)," ";
		if (cmp>0)
		{
			mlet	lval="("$(lval)")";
		}
		index	cmp=$(rval)," ";
		if (cmp>0)
		{
			mlet	rval="("$(rval)")";
		}

		// operator
		mlet	mne="xxx";
		strcmp	cmp=$(opr),"eq";
		if (cmp=0)
		{
			mlet	opr="==";
			mlet	mne="feq";
		}
		strcmp	cmp=$(opr),"neq";
		if (cmp=0)
		{
			mlet	opr="!=";
			mlet	mne="fne";
		}
		strcmp	cmp=$(opr),"gte";
		if (cmp=0)
		{
			mlet	opr=">=";
			mlet	mne="fge";
		}
		strcmp	cmp=$(opr),"lte";
		if (cmp=0)
		{
			mlet	opr="<=";
			mlet	mne="fle";
		}
		strcmp	cmp=$(opr),"gt";
		if (cmp=0)
		{
			mlet	opr=">";
			mlet	mne="fgt";
		}
		strcmp	cmp=$(opr),"lt";
		if (cmp=0)
		{
			mlet	opr="<";
			mlet	mne="flt";
		}
		// error check
		strcmp	cmp=$(mne),"xxx";
		if (cmp=0)
		{
			// ERROR:
			errmsg	"mcoc_matf_compare: unsupported operator ("$(opr)")";
			leave	stop_error;
		}
		check_param_lr	"mcoc_matf_compare";
		mlet	do_blk_mcoc_matf_compare=$(opr);

		// assembler
		fprint	fout,"// "$(lval)" "$(opr)" "$(rval);
		strcmp	cmp=$(opr),"==";
		if (cmp)
		{
			strcmp	cmp=$(opr),"!=";
		}
		if (cmp)
		{
			strcmp	cmp=$(opr),">=";
		}
		if (cmp)
		{
			strcmp	cmp=$(opr),"<";
		}
		if (cmp=0)
		{
			fprint	fout,$,;
			fprint	fout,"fcmp"$,;
		}
		strcmp	cmp=$(opr),">";
		if (cmp=0)
		{
			mlet	opr="<";
			mlet	mne="flt";
			fprint	fout," ==> "$(rval)" "$(opr)" "$(lval)$,;
			fprint	fout,"swap"$,;
			fprint	fout,"fcmp"$,;
		}
		strcmp	cmp=$(opr),"<=";
		if (cmp=0)
		{
			mlet	opr=">=";
			mlet	mne="fge";
			fprint	fout," ==> "$(rval)" "$(opr)" "$(lval)$,;
			fprint	fout,"swap"$,;
			fprint	fout,"fcmp"$,;
		}
		asm_bool;

		mlet	do_blk_mcoc_matf_compare=$(lval)" "
				$(do_blk_mcoc_matf_compare)" "$(rval);
		opt_fpu_need=true;
	}
	procedure	do_blk_mcoc_matf_unary
	{
		var		cmp;
		macro	opr;
		macro	mne;
		macro	nval;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	opr=$(do_$(dxml));
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					mlet	nval=$(do_$(dxml));
				}
			}
		}
		tolower		opr;
		index	cmp=$(nval)," ";
		if (cmp>0)
		{
			mlet	nval="("$(nval)")";
		}

		// operator
		mlet	mne="xxx";
		strcmp	cmp=$(opr),"-";
		if (cmp=0)
		{
			mlet	mne="fneg";
		}
		strcmp	cmp=$(opr),"sq";
		if (cmp=0)
		{
			mlet	mne="fmul";
		}
		strcmp	cmp=$(opr),"2*";
		if (cmp=0)
		{
			mlet	mne="fadd";
		}
		strcmp	cmp=$(mne),"xxx";
		if (cmp=0)
		{
			// ERROR:
			errmsg	"mcoc_matf_unary: unsupported operator ("$(opr)")";
			leave	stop_error;
		}
		mlet	do_blk_mcoc_matf_unary=$(opr)" "$(nval);
		opt_fpu_need=true;

		// assembler
		fprint	fout,"// "$(opr)" "$(nval)$,;
		strcmp	cmp=$(opr),"-";
		if (cmp=0)
		{
			fprint	fout,$(mne)"	0"$,;
		}
		strcmp	cmp=$(opr),"sq";
		if (cmp)
		{
			strcmp	cmp=$(opr),"2*";
		}
		if (cmp=0)
		{
			fprint	fout,"dupl"$,;
			fprint	fout,$(mne)$,;
		}
	}
	procedure	do_blk_mcoc_matf_isinf
	{
		var		cmp;
		macro	nval;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					mlet	nval=$(do_$(dxml));
				}
			}
		}
		mlet	do_blk_mcoc_matf_isinf="isinf ("$(nval)")";
		opt_fpu_need=true;

		// assembler
//	%%%%%%%%%%%%%%%%	blky2sama_math.incl
		fprint	fout,"// abs ("$(nval)")"$,;
		fprint	fout,"lsl"$,;
		fprint	fout,"lsr"$,;
		fprint	fout,"// isinf ("$(nval)")"$,;
		fprint	fout,"fcmp	half_inf"$,;
		fprint	fout,"and	sama_hcmp_cf"$,;
		fprint	fout,"swap	false"$,;
		asm_label;
		fprint	fout,"njmp	"$(asm_label)$,;
		fprint	fout,"or	true"$,;
		fprint	fout,$(asm_label)":"$,;
	}
