			}
		}
		tolower		func;
		strcmp	cmp=$(nval),"";
		if (cmp=0)
		{
			// ERROR:
			errmsg	"mcoc_math_funci: no parameter";
			leave	stop_error;
		}
		need_stnd=true;

		// assembler
		fprint	fout,"// "$(func)" ("$(nval)")"$,;

		mlet	do_blk_mcoc_math_funci=$(func)" ("$(nval)")";
		index	cmp=$(nval)," ";
		if (cmp>0)
		{
			mlet	nval="("$(nval)")";
		}

		// function
		strcmp	cmp=$(func),"abs";
		if (cmp=0)
		{
			// assembler
			fprint	fout,"dupl"$,;					// X,X
			fprint	fout,"and	SGN_BIT"$,;			// X,X&SGN
			asm_label;
			fprint	fout,"njmp	"$(asm_label)$,;	// X
			fprint	fout,"neg"$,;					// -X
			fprint	fout,$(asm_label)":"$,;
		}
		strcmp	cmp=$(func),"sgn";
		if (cmp=0)
		{
			// assembler
			fprint	fout,"dupl"$,;					// X,X
			asm_label;
			fprint	fout,"njmp	"$(asm_label)$,;	// X
			fprint	fout,"swap	1"$,;				// 1,X
			fprint	fout,"and	SGN_BIT"$,;			// 1,X&SGN
			fprint	fout,"njmp	"$(asm_label)$,;	// 1
			fprint	fout,"pop"$,;
			fprint	fout,"push	-1"$,;				// -1
			fprint	fout,$(asm_label)":"$,;
		}
		strcmp	cmp=$(func),"rand";
		if (cmp=0)
		{
			// assembler
			fprint	fout,"// rand"$,;
			fprint	fout,"mulu*	[_rtlb_rnd_seed],_rtlb_rand_aw"$,;
			fprint	fout,"add	_rtlb_rand_cw"$,;		// X,RND
			fprint	fout,"// rand % "$(nval)$,;
			fprint	fout,"swap"$,;						// RND,X
			fprint	fout,"dupl"$,;						// RND,X,X
			asm_label;
			fprint	fout,"njmp	"$(asm_label)$,;		// RND,X
			fprint	fout,"divu*"$,;						// RND/X
			fprint	fout,"pop	// discard Quo"$,;
			fprint	fout,"ldw	_r1	// load Rem"$,;		// RND%X
			fprint	fout,"push	0	// dummy"$,;		// RND%X,0
			fprint	fout,$(asm_label)":"$,;
			fprint	fout,"pop"$,;						// RND%X
		}
		strcmp	cmp=$(func),"rseed";
		if (cmp=0)
		{
			// assembler
			fprint	fout,"dupl"$,;
			fprint	fout,"stw	_rtlb_rnd_seed"$,;
		}
	}
	procedure	do_blk_mcoc_math_ascii
	{
		var		cmp;
		var		chr;
		macro	cstr;
		macro	shex;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	cstr=$(do_$(dxml));
				}
			}
		}

		// ascii code
		gsub	"&lt;","<",cstr;
		psub	"^(.).*","\1",cstr;
		gsub	"#","##",cstr;
		chr2num		chr=$(cstr);
		if (chr>255)
		{
			num2str		shex=chr,"%04x";

			// assembler
			fprint	fout,"// S-JIS 0x"$(shex)"(=0a"$(cstr)")"$,;
		}
		else
		{
			num2str		shex=chr,"%02x";

			// assembler
			fprint	fout,"// ASCII 0x"$(shex)"(=0a"$(cstr)")"$,;
		}
		mlet	do_blk_mcoc_math_ascii="0x"$(shex);

		// assembler
		fprint	fout,"push	0x"$(shex)$,;	// do not use '0a'

		val_done=true;
	}
	procedure	do_blk_mcoc_math_post
	{
		var		cmp;
		var		val;
		macro	mne;
		macro	opr;
		macro	vnam;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"VAR";
					if (cmp=0)
					{
						mlet	vnam=$(do_$(dxml));
					}
					else
					{
						mlet	opr=$(do_$(dxml));
					}
				}
			}
		}

		// operator
		gsub	"&lt;","<",opr;
		gsub	"&gt;",">",opr;
		mlet	do_blk_mcoc_math_post=$(vnam)" "$(opr);
		val=1;
		mlet	mne="xxx";
		strcmp	cmp=$(opr),"++", left;
		if (cmp)
		{
			strcmp	cmp=$(opr),"--", left;
		}
		if (cmp=0)
		{
			strcmp	cmp=$(opr),"2", right;
			if (cmp=0)
			{
				val=2;
			}
			strcmp	cmp=$(opr),"4", right;
			if (cmp=0)
			{
				val=4;
			}
			strcmp	cmp=$(opr),"++", left;
			if (cmp=0)
			{
				mlet	mne="add";
				mlet	opr="+ "#(val);
			}
			else
			{
				mlet	mne="sub";
				mlet	opr="- "#(val);
			}
		}
		else
		{
			// ERROR:
			errmsg	"mcoc_math_post: unsupported operator ("$(opr)")";
			leave	stop_error;
		}

		// assembler
		fprint	fout,"// "$(do_blk_mcoc_math_post)$,;
		fprint	fout,"dupl	["$(vnam)"]"$,;
		fprint	fout,$(mne)"	#"$,,val;
		fprint	fout,"stw	"$(vnam)$,;
	}
	procedure	do_blk_mcoc_math_unary
	{
		var		cmp;
		macro	opr;
		macro	mne;
		macro	nval;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	opr=$(do_$(dxml));
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					mlet	nval=$(do_$(dxml));
				}
			}
		}
		tolower		opr;
		index	cmp=$(nval)," ";
		if (cmp>0)
		{
			mlet	nval="("$(nval)")";
		}

		// operator
		mlet	mne="xxx";
		strcmp	cmp=$(opr),"-";
		if (cmp=0)
		{
			mlet	mne="neg";
		}
		strcmp	cmp=$(opr),"~";
		if (cmp=0)
		{
			mlet	mne=$(str_not);
		}
		strcmp	cmp=$(opr),"!";
		if (cmp)
		{
			strcmp	cmp=$(opr),"!!";
		}
		if (cmp=0)
		{
			mlet	mne="eor";
		}
		strcmp	cmp=$(opr),"sq";
		if (cmp=0)
		{
			mlet	mne="muls*";
		}
		strcmp	cmp=$(opr),"1+";
		if (cmp=0)
		{
			mlet	mne="add";
		}
		strcmp	cmp=$(opr),"-1+";
		if (cmp=0)
		{
			mlet	mne="sub";
		}
		strcmp	cmp=$(opr),"2*";
		if (cmp=0)
		{
			mlet	mne="add";
		}
		strcmp	cmp=$(opr),"r6+";
		if (cmp=0)
		{
			mlet	mne="add";
		}
		strcmp	cmp=$(mne),"xxx";
		if (cmp=0)
		{
			// ERROR:
			errmsg	"mcoc_math_unary: unsupported operator ("$(opr)")";
			leave	stop_error;
		}
		mlet	do_blk_mcoc_math_unary=$(opr)" "$(nval);

		// assembler
		fprint	fout,"// "$(opr)" "$(nval)$,;
		strcmp	cmp=$(opr),"-";
		if (cmp=0)
		{
			fprint	fout,$(mne)$,;
		}
		strcmp	cmp=$(opr),"~";
		if (cmp=0)
		{
			fprint	fout,$(mne)$,;
		}
		strcmp	cmp=$(opr),"!";
		if (cmp)
		{
			strcmp	cmp=$(opr),"!!";
		}
		if (cmp=0)
		{
			strcmp	cmp=$(opr),"!";
			asm_bool	( cmp=0 );
		}
		strcmp	cmp=$(opr),"sq";
		if (cmp)
		{
			strcmp	cmp=$(opr),"2*";
		}
		if (cmp=0)
		{
			fprint	fout,"dupl"$,;
			fprint	fout,$(mne)$,;
		}
		strcmp	cmp=$(opr),"1+";
		if (cmp)
		{
			strcmp	cmp=$(opr),"-1+";
		}
		if (cmp=0)
		{
			fprint	fout,$(mne)"	1"$,;
		}
		strcmp	cmp=$(opr),"r6+";
		if (cmp=0)
		{
			fprint	fout,$(mne)"	[_r6]"$,;
		}
	}
	procedure	do_blk_mcoc_math_label
	{
		var		cmp;
		macro	lnam;
		macro	lval;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"NAME";
					if (cmp=0)
					{
						mlet	lnam=$(do_$(dxml));
					}
					else
					{
						mlet	lval=$(do_$(dxml));
					}
				}
			}
		}
		pgsub	"[ 	]+","",lval;
		pgsub	"&lt;","<",lval;
		strcmp	cmp=$(lnam),"";
		if (cmp)
		{
			strcmp	cmp=$(lval),"";
		}
		if (cmp=0)
		{
			// ERROR:
			errmsg	"mcoc_math_label: bad parameter";
			leave	stop_error;
		}

		// equation list
		static : macro	elst_equ#(elst_cnt)="equ	"$(lnam)","$(lval);
		elst_cnt=elst_cnt + 1;
	}
	procedure	do_blk_mcoc_math_number
	{
		var		cmp;
		macro	nval;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					fget_xml;
					mlet	nval=$(fget_xml);
					continue;
				}
				do_$(dxml);
			}
		}
		gsub	"&lt;","<",nval;
		pgsub	"[ 	]+","",nval;
		mlet	do_blk_mcoc_math_number=$(nval);

		// assembler
		fprint	fout,"// "$(nval)$,;
		fprint	fout,"push	"$(nval)$,;

		val_done=true;
	}
	procedure	do_blk_mcoc_math_bit_binary
	{
		var		cmp;
		macro	opr;
		macro	lval;
		macro	rval;
		macro	mne;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	opr=$(do_$(dxml));
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"data";
					if (cmp)
					{
						strcmp	cmp=$(dnam),"A";
					}
					if (cmp=0)
					{
						mlet	lval=$(do_$(dxml));
					}
					else
					{
						mlet	rval=$(do_$(dxml));
					}
				}
			}
		}
		index	cmp=$(lval)," ";
		if (cmp>0)
		{
			mlet	lval="("$(lval)")";
		}
		index	cmp=$(rval)," ";
		if (cmp>0)
		{
			mlet	rval="("$(rval)")";
		}

		// operator
		gsub	"&lt;","<",opr;
		tolower		opr;
		mlet	mne="xxx";
		strcmp	cmp=$(opr),"&";
		if (cmp=0)
		{
			mlet	opr="&";
			mlet	mne=$(str_and);
		}
		strcmp	cmp=$(opr),"|";
		if (cmp=0)
		{
			mlet	mne=$(str_or);
		}
		strcmp	cmp=$(opr),"<<";
		if (cmp=0)
		{
			mlet	opr="<<";
			mlet	mne="asl";
		}
		strcmp	cmp=$(opr),">>";
		if (cmp=0)
		{
			mlet	opr=">>";
			mlet	mne="asr";
		}
		strcmp	cmp=$(opr),">>>";
		if (cmp=0)
		{
			mlet	opr=">>>";
			mlet	mne="lsr";
		}
		pindex	cmp=$(opr),"^[<>]+$";
		if (cmp>0)
		{
			// shift operators
			strcmp	cmp=$(rval),"";
			if (cmp=0)
			{
				mlet	rval="1";
			}
			else
			{
				// assembler
				fprint	fout,"pop	// discard rval(="$(rval)")"$,;
			}
			if ($(rval)<0 | 15<$(rval))
			{
				// ERROR:
				errmsg	"mcoc_math_bit_binary: "
						"rval of shift operator must be '1'"$,;
				leave	stop_error;
			}
		}
		strcmp	cmp=$(opr),"^";
		if (cmp=0)
		{
			mlet	mne="eor";
		}

		// error check
		strcmp	cmp=$(mne),"xxx";
		if (cmp=0)
		{
			// ERROR:
			errmsg	"mcoc_math_bit_binary: unsupported operator ("$(opr)")";
			leave	stop_error;
		}
		check_param_lr	"mcoc_math_bit_binary";

		// assembler
		fprint	fout,"// "$(lval)" "$(opr)" "$(rval)$,;
		pindex	cmp=$(opr),"^[<>]+$";
		if (cmp>0)
		{
			// bit wise shift operator
			var		sft=$(rval);

			// more than 7
			if (sft>7)
			{
				strcmp	cmp=$(opr),"<<";
				if (cmp=0)
				{
					fprint	fout,"and	BYTE_LO"$,;
					fprint	fout,"cend"$,;

					sft=sft - 8;
				}
				strcmp	cmp=$(opr),">>";
				if (false & cmp=0)	// false: Using 8 asr has more advantage.
				{
					fprint	fout,"dupl"$,;
					fprint	fout,"and	SGN_BIT"$,;
					asm_label;
					fprint	fout,"cjmp	"$(asm_label)"_else"$,;
					fprint	fout,"// positive"$,;
					fprint	fout,"cend"$,;
					fprint	fout,"and	BYTE_LO"$,;
					fprint	fout,"jmp	"$(asm_label)"_endif"$,;
					fprint	fout,$(asm_label)"_else:"$,;
					fprint	fout,"// negative"$,;
					fprint	fout,"or	BYTE_LO"$,;
					fprint	fout,"cend"$,;
					fprint	fout,$(asm_label)"_endif:"$,;

					sft=sft - 8;
				}
				strcmp	cmp=$(opr),">>>";
				if (cmp=0)
				{
					fprint	fout,"cend"$,;
					fprint	fout,"and	BYTE_LO"$,;

					sft=sft - 8;
				}
			}
			// remaining
			var		idx=0;
			while (idx<sft)
			{
				fprint	fout,$(mne)$,;

				// continue
				idx=idx + 1;
			}
		}
		else
		{
			// bit wise binary operator
			fprint	fout,$(mne)$,;
		}

		mlet	do_blk_mcoc_math_bit_binary=$(lval)" "$(opr)" "$(rval);
	}
	procedure	do_blk_mcoc_pack
	{
		var		cmp;
		var		stat;
		var		cnts;
		macro	enbl;
		macro	cmnt;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			if (stat=0)
			{
				pindex	cmp=$(cxml),"^<statement[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^<next[ >]";
				}
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// continue
					pindex	cmp=$(cxml),"^<statement[ >]";
					if (cmp>0)
					{
						// pack
						strcmp	cmp=$(enbl),"true";
						if (cmp=0)
						{
							stat=1;

							// comment
							strcmp	cmp=$(cmnt),"";
							if (cmp)
							{
								strcmp	cmp=$(cmnt),"#",left;
								if (cmp)
								{
									strcmp	cmp=$(cmnt),"//",left;
								}
								if (cmp)
								{
									mlet	cmnt="// "$(cmnt);
								}
								
								// assembler
								fputl	fout,$(cmnt);
							}
						}
						else
						{
							stat=3;
						}
						continue;
					}
					else
					{
						// empty block
						stat=2;
						mlet	enbl="false";
					}
				}
			}
			if (stat=1 | stat=3)
			{
				// pack block
				pindex	cmp=$(cxml),"^<statement[ >]";
				if (cmp>0)
				{
					cnts=cnts + 1;
				}
				pindex	cmp=$(cxml),"^</statement[ >]";
				if (cmp>0)
				{
					// end of statement
					if (cnts>0)
					{
						cnts=cnts - 1;
						continue;
					}

					// end of pack
					stat=2;
					continue;
				}
				if (stat=3)
				{
					// disabled pack
					continue;
				}
			}
			if (stat=2)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// end of pack
					break;
				}
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				if (stat=0)
				{
					strcmp	cmp=$(dxml),"field";
					if (cmp=0)
					{
						strcmp	cmp=$(dnam),"ENB";
						if (cmp=0)
						{
							mlet	enbl=$(do_$(dxml));
							tolower		enbl;
						}
						else
						{
							mlet	cmnt=$(do_$(dxml));
						}
					}
				}
			}
		}
	}
	procedure	do_blk_mcoc_swap
	{
		var		cmp;
		macro	vnam1;
		macro	vnam2;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"A";
					if (cmp=0)
					{
						mlet	vnam1=$(do_$(dxml));
					}
					else
					{
						mlet	vnam2=$(do_$(dxml));
					}
				}
			}
		}

		// assembler
		fprint	fout,"// swap "$(vnam1)" and "$(vnam2)$,;
		fprint	fout,"stw	["$(vnam1)"],["$(vnam2)"],"$(vnam1)$,;
		fprint	fout,"stw	"$(vnam2)$,;
	}
	procedure	do_blk_mcoc_task
	{
		var		cmp;
		var		stat;
		macro	tskf;

		// assembler
		if (defp_1st)
		{
			defp_1st=false;
			fprint	fout,$,;
			fprint	fout,"// halt"$,;
			fprint	fout,"jmp	_rtlb_prog_halt"$,;
		}

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			if (stat=0)
			{
				pindex	cmp=$(cxml),"^<statement[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^<next[ >]";
				}
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// continue
					pindex	cmp=$(cxml),"^<statement[ >]";
					if (cmp>0)
					{
						// task
						stat=1;

						// assembler
						fprint	fout,$,;
						fprint	fout,"// task "$(tskf)$,;
						fprint	fout,"_rtlb_task_"$(tskf)":"$,;

						continue;
					}
					else
					{
						// empty block
						stat=2;

						// ERROR:
						errmsg	"mcoc_task: inhibited empty block.";
						leave	stop_error;
					}
				}
			}
			if (stat=1)
			{
				// task block
				pindex	cmp=$(cxml),"^</statement[ >]";
				if (cmp>0)
				{
					// end of statement

					// assembler
					fprint	fout,"// end of task"$,;
					fprint	fout,"rtn"$,;

					// end of task
					stat=2;
					continue;
				}
			}
			if (stat=2)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
				if (cmp<=0)
				{
					pindex	cmp=$(cxml),"^</block[ >]";
				}
				if (cmp>0)
				{
					// end of task
					break;
				}
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				if (stat=0)
				{
					strcmp	cmp=$(dxml),"field";
					if (cmp=0)
					{
						mlet	tskf=$(do_$(dxml));
						tolower		tskf;
						if (tsk_def_$(tskf))
						{
							// ERROR:
							errmsg	"mcoc_task: re-defined task "$(tskf);
							leave	stop_error;
						}
						tsk_def_$(tskf)=true;
					}
				}
			}
		}
	}
	procedure	do_blk_math_constrain
	{
		var		cmp;
		macro	nval;
		macro	nlow;
		macro	nhgh;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"VALUE";
					if (cmp=0)
					{
						mlet	nval=$(do_$(dxml));
					}
					strcmp	cmp=$(dnam),"LOW";
					if (cmp=0)
					{
						mlet	nlow=$(do_$(dxml));
					}
					strcmp	cmp=$(dnam),"HIGH";
					if (cmp=0)
					{
						mlet	nhgh=$(do_$(dxml));
					}
				}
			}
		}
		mlet	do_blk_math_constrain="clip ("$(nval)","$(nlow)","$(nhgh)")";

		// assembler
//	%%%%%%%%%%%%%%%%	blky2sama_stnd.incl
		fprint	fout,"// clip ("$(nval)","$(nlow)","$(nhgh)")"$,;
		fprint	fout,"stw	_r0"$,;				// X,LO; r0=HI
		fprint	fout,"dupl"$,;					// X,LO,LO
		fprint	fout,"stw	_r1"$,;				// X,LO; r1=LO
		fprint	fout,"swap"$,;					// LO,X
		fprint	fout,"dupl"$,;					// LO,X,X
		fprint	fout,"stw	_r2"$,;				// LO,X; r2=X
		fprint	fout,"// X<=LO? LO"$,;
		fprint	fout,"cmp"$,;					// NCVZS(LO-X)
		fprint	fout,"and	sama_cmp_sf"$,;		// S(LO<X)
		fprint	fout,"swap	[_r1]"$,;			// LO,S(LO<X)
		asm_label;
		fprint	fout,"njmp	"$(asm_label)$,;	// LO
		fprint	fout,"// X>=HI? HI"$,;
		fprint	fout,"pop"$,;					// -
		fprint	fout,"dupl	[_r0]"$,;			// HI,HI
		fprint	fout,"swap	[_r2]"$,;			// HI,X,HI
		fprint	fout,"cmp"$,;					// HI,NCVZS(X-HI)
		fprint	fout,"and	sama_cmp_sf"$,;		// HI,S(X<HI)
		fprint	fout,"njmp	"$(asm_label)$,;	// HI
		fprint	fout,"pop"$,;					// -
		fprint	fout,"ldw	_r2"$,;				// X
		fprint	fout,$(asm_label)":"$,;
	}
	procedure	do_blk_math_number
	{
		var		cmp;
		macro	nval;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				mlet	nval=$(do_$(dxml));
			}
		}
		mlet	do_blk_math_number=$(nval);

		// assembler
		fprint	fout,"// "$(nval)$,;
		fprint	fout,"push	"$(nval)$,;

		val_done=true;
	}
	procedure	do_blk_math_change
	{
		var		cmp;
		macro	vnam;
		macro	nval;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	vnam=$(do_$(dxml));
				}
				strcmp	cmp=$(dxml),"block";
				if (cmp)
				{
					strcmp	cmp=$(dxml),"value";
				}
				if (cmp=0)
				{
					mlet	nval=$(do_$(dxml));
				}
			}
		}
		index	cmp=$(nval)," ";
		if (cmp>0)
		{
			mlet	nval="("$(nval)")";
		}

		// assembler
		fprint	fout,"// "$(vnam)" += "$(nval)$,;
		fprint	fout,"add	["$(vnam)"]"$,;
		fprint	fout,"stw	"$(vnam)$,;
	}
	procedure	do_blk_mcoc_math_arithmetic
	{
		var		cmp;
		macro	opr;
		macro	lval;
		macro	rval;
		macro	mne;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				nmacro	_xml_name;
				macro	dnam=$(_xml_name);
				do_$(dxml);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					mlet	opr=$(do_$(dxml));
					tolower		opr;
				}
				strcmp	cmp=$(dxml),"value";
				if (cmp=0)
				{
					strcmp	cmp=$(dnam),"A";
					if (cmp)
					{
						strcmp	cmp=$(dnam),"VAR1";
					}
					if (cmp=0)
					{
						mlet	lval=$(do_$(dxml));
					}
					else
					{
						mlet	rval=$(do_$(dxml));
					}
				}
			}
		}
		tolower		opr;
		index	cmp=$(lval)," ";
		if (cmp>0)
		{
			mlet	lval="("$(lval)")";
		}
		index	cmp=$(rval)," ";
		if (cmp>0)
		{
			mlet	rval="("$(rval)")";
		}

		// operator
		mlet	mne="xxx";
		strcmp	cmp=$(opr),"add";
		if (cmp)
		{
			strcmp	cmp=$(opr),"+";
		}
		if (cmp=0)
		{
			mlet	opr="+";
			mlet	mne="add";
		}
		strcmp	cmp=$(opr),"minus";
		if (cmp)
		{
			strcmp	cmp=$(opr),"-";
		}
		if (cmp=0)
		{
			mlet	opr="-";
			mlet	mne="sub";
		}
		strcmp	cmp=$(opr),"multiply";
		if (cmp)
		{
			strcmp	cmp=$(opr),"*";
		}
		if (cmp=0)
		{
			mlet	opr="*";
			mlet	mne="muls*";
		}
		strcmp	cmp=$(opr),"divide";
		if (cmp)
		{
			strcmp	cmp=$(opr),"/";
		}
		if (cmp=0)
		{
			mlet	opr="/";
			mlet	mne="divs*";
		}
		strcmp	cmp=$(opr),"modulo";
		if (cmp)
		{
			strcmp	cmp=$(opr),"%";
		}
		if (cmp=0)
		{
			mlet	opr="%";
			mlet	mne="divs*";
		}
		strcmp	cmp=$(opr),"min";
		if (cmp)
		{
			strcmp	cmp=$(opr),"max";
		}
		if (cmp=0)
		{
			// minimum / maximum operator
			mlet	mne="cjmp";
			strcmp	cmp=$(opr),"min";
			if (cmp=0)
			{
				mlet	mne="njmp";
			}
		}

		// error check
		strcmp	cmp=$(mne),"xxx";
		if (cmp=0)
		{
			// ERROR:
			errmsg	"mcoc_math_arithmetic: unsupported operator ("$(opr)")";
			leave	stop_error;
		}
		check_param_lr	"mcoc_math_arithmetic";
		mlet	do_blk_mcoc_math_arithmetic=$(lval)" "$(opr)" "$(rval);

		// assembler
		fprint	fout,"// "$(lval)" "$(opr)" "$(rval)$,;
		strcmp	cmp=$(opr),"%";
		if (cmp=0)
		{
			fprint	fout,$(mne)$,;
			fprint	fout,"// divs* returns Quo (also _r0=_r2=Quo, _r1=Rem)"$,;
			fprint	fout,"pop	// discard Quo"$,;
			fprint	fout,"ldw	_r1	// load Rem"$,;

			mlet	opr="";
		}
		strcmp	cmp=$(opr),"min";
		if (cmp)
		{
			strcmp	cmp=$(opr),"max";
		}
		if (cmp=0)
		{
//	%%%%%%%%%%%%%%%%	blky2sama_stnd.incl
			fprint	fout,"stw	_r1"$,;			// [_r0]
			fprint	fout,"dupl"$,;				// [_r0],[_r0]
			fprint	fout,"cmp	[_r1]"$,;		// [_r0],NCVZS([_r0]-[_r1])
			fprint	fout,"and	sama_cmp_sf"$,;	// [_r0],S([_r0]<[_r1])
			asm_label;
			fprint	fout,$(mne)"	"$(asm_label)$,;	// [_r0]
			fprint	fout,"pop"$,;
			fprint	fout,"ldw	_r1"$,;					// [_r1]
			fprint	fout,$(asm_label)":"$,;

			mlet	opr="";
		}
		strcmp	cmp=$(opr),"";
		if (cmp)
		{
			fprint	fout,$(mne)$,;
		}
	}
	procedure	do_blk_math_arithmetic
	{
		do_blk_mcoc_math_arithmetic;
		mlet	do_blk_math_arithmetic=$(do_blk_mcoc_math_arithmetic);
	}
	procedure	do_blk_mcoc_matf_number
	{
		var		cmp;
		macro	nval;

		while (true)
		{
			fget_xml;
			macro	cxml=$(fget_xml);
			pindex	cmp=$(cxml),"^</block[ >]";
			if (cmp<=0)
			{
				pindex	cmp=$(cxml),"^<next[ >]";
			}
			if (cmp>0)
			{
				break;
			}

			pindex	cmp=$(cxml),"^<[^/]";
			if (cmp>0)
			{
				static : analyze_xml	$(cxml);
				macro	dxml=$(_xml_);
				strcmp	cmp=$(dxml),"field";
				if (cmp=0)
				{
					fget_xml;
					mlet	nval=$(fget_xml);
					continue;
				}
				do_$(dxml);
			}
		}
		gsub	"&lt;","<",nval;
		pgsub	"[ 	]+","",nval;
		mlet	do_blk_mcoc_matf_number="half["$(nval)"]";

		// assembler
		fprint	fout,"push	half["$(nval)"]"$,;

		val_done=true;
	}
